# 88CAMPCAR 環境設定

# 管理者パスワード（必須 / ハッシュ）
# 生成コマンド:
#   npm run gen:admin-hash "your_admin_password"
# 出力された文字列をそのまま設定
ADMIN_PASS_HASH=scrypt$16384$8$1$your_salt_hex$your_hash_hex

# メール通知設定（Gmail）
# Gmail の「アプリパスワード」を設定してください
# → https://myaccount.google.com/apppasswords
ADMIN_EMAIL=your_email@gmail.com
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password

# サイトURL（メール内のリンク用・本番では実際のドメインを設定）
BASE_URL=http://localhost:3000

# ポート番号（デフォルト: 3000）
PORT=3000
